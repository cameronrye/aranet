{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus data source for Aranet metrics",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__elements": {},
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "Monitor Aranet environmental sensors - CO2, temperature, humidity, pressure, radon, radiation, and battery levels",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Service Status",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            { "options": { "0": { "text": "Stopped" }, "1": { "text": "Running" } }, "type": "value" }
          ]
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Collector Status",
      "type": "stat",
      "targets": [{ "expr": "aranet_collector_running", "legendFormat": "Status" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }] }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 2,
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Collector Uptime",
      "type": "stat",
      "targets": [{ "expr": "aranet_collector_uptime_seconds", "legendFormat": "Uptime" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green", "value": null }] }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 3,
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Total Successful Polls",
      "type": "stat",
      "targets": [{ "expr": "sum(aranet_device_poll_success_total{device=~\"$device\"})", "legendFormat": "Success" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 4,
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Total Failed Polls",
      "type": "stat",
      "targets": [{ "expr": "sum(aranet_device_poll_failure_total{device=~\"$device\"})", "legendFormat": "Failures" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5000 },
              { "color": "red", "value": 30000 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "id": 5,
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Poll Duration",
      "type": "stat",
      "targets": [{ "expr": "aranet_device_poll_duration_ms{device=~\"$device\"}", "legendFormat": "{{device}}" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "id": 6,
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "WS Messages Dropped",
      "type": "stat",
      "targets": [{ "expr": "aranet_ws_messages_dropped_total", "legendFormat": "Dropped" }]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "Air Quality",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ppm",
          "min": 400,
          "max": 2500,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1000 },
              { "color": "red", "value": 1400 }
            ]
          }
        }
      },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 6 },
      "id": 10,
      "options": { "showThresholdLabels": true, "showThresholdMarkers": true, "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "CO2 Level",
      "type": "gauge",
      "targets": [{ "expr": "aranet_co2_ppm{device=~\"$device\"}", "legendFormat": "{{device}}" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ppm",
          "custom": { "lineWidth": 2, "fillOpacity": 15, "gradientMode": "scheme", "thresholdsStyle": { "mode": "line" } },
          "color": { "mode": "continuous-GrYlRd" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1000 },
              { "color": "red", "value": 1400 }
            ]
          }
        }
      },
      "gridPos": { "h": 6, "w": 16, "x": 8, "y": 6 },
      "id": 11,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "calcs": ["min", "max", "mean", "lastNotNull"] } },
      "title": "CO2 Over Time",
      "type": "timeseries",
      "targets": [{ "expr": "aranet_co2_ppm{device=~\"$device\"}", "legendFormat": "{{device}}" }]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 12 },
      "id": 102,
      "title": "Environment",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "steps": [
              { "color": "blue", "value": null },
              { "color": "green", "value": 18 },
              { "color": "yellow", "value": 26 },
              { "color": "red", "value": 30 }
            ]
          }
        }
      },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 13 },
      "id": 20,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "calcs": ["min", "max", "mean", "lastNotNull"] } },
      "title": "Temperature",
      "type": "timeseries",
      "targets": [{ "expr": "aranet_temperature_celsius{device=~\"$device\"}", "legendFormat": "{{device}}" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 30 },
              { "color": "green", "value": 40 },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 70 }
            ]
          }
        }
      },
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 13 },
      "id": 21,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "calcs": ["min", "max", "mean", "lastNotNull"] } },
      "title": "Humidity",
      "type": "timeseries",
      "targets": [{ "expr": "aranet_humidity_percent{device=~\"$device\"}", "legendFormat": "{{device}}" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "pressurehpa",
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "color": { "mode": "palette-classic" }
        }
      },
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 13 },
      "id": 22,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "calcs": ["min", "max", "mean", "lastNotNull"] } },
      "title": "Atmospheric Pressure",
      "type": "timeseries",
      "targets": [{ "expr": "aranet_pressure_hpa{device=~\"$device\"}", "legendFormat": "{{device}}" }]
    },
    {
      "collapsed": true,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 20 },
      "id": 103,
      "title": "Radon & Radiation",
      "type": "row",
      "panels": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "fieldConfig": {
            "defaults": {
              "unit": "Bq/m\u00b3",
              "min": 0,
              "color": { "mode": "thresholds" },
              "thresholds": {
                "steps": [
                  { "color": "green", "value": null },
                  { "color": "yellow", "value": 150 },
                  { "color": "red", "value": 300 }
                ]
              }
            }
          },
          "gridPos": { "h": 6, "w": 6, "x": 0, "y": 21 },
          "id": 30,
          "options": { "showThresholdLabels": true, "showThresholdMarkers": true, "reduceOptions": { "calcs": ["lastNotNull"] } },
          "title": "Radon Level",
          "type": "gauge",
          "targets": [{ "expr": "aranet_radon_bqm3{device=~\"$device\"}", "legendFormat": "{{device}}" }]
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "fieldConfig": {
            "defaults": {
              "unit": "Bq/m\u00b3",
              "custom": { "lineWidth": 2, "fillOpacity": 15, "gradientMode": "scheme", "thresholdsStyle": { "mode": "line" } },
              "color": { "mode": "continuous-GrYlRd" },
              "thresholds": {
                "steps": [
                  { "color": "green", "value": null },
                  { "color": "yellow", "value": 150 },
                  { "color": "red", "value": 300 }
                ]
              }
            }
          },
          "gridPos": { "h": 6, "w": 18, "x": 6, "y": 21 },
          "id": 31,
          "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "calcs": ["min", "max", "mean", "lastNotNull"] } },
          "title": "Radon Over Time",
          "type": "timeseries",
          "targets": [{ "expr": "aranet_radon_bqm3{device=~\"$device\"}", "legendFormat": "{{device}}" }]
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "fieldConfig": {
            "defaults": {
              "unit": "\u00b5Sv/h",
              "custom": { "lineWidth": 2, "fillOpacity": 10 },
              "color": { "mode": "palette-classic" }
            }
          },
          "gridPos": { "h": 6, "w": 12, "x": 0, "y": 27 },
          "id": 32,
          "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "calcs": ["min", "max", "mean", "lastNotNull"] } },
          "title": "Radiation Rate",
          "type": "timeseries",
          "targets": [{ "expr": "aranet_radiation_rate_usvh{device=~\"$device\"}", "legendFormat": "{{device}}" }]
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "fieldConfig": {
            "defaults": {
              "unit": "mSv",
              "custom": { "lineWidth": 2, "fillOpacity": 10 },
              "color": { "mode": "palette-classic" }
            }
          },
          "gridPos": { "h": 6, "w": 12, "x": 12, "y": 27 },
          "id": 33,
          "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "calcs": ["min", "max", "mean", "lastNotNull"] } },
          "title": "Total Radiation Dose",
          "type": "timeseries",
          "targets": [{ "expr": "aranet_radiation_total_msv{device=~\"$device\"}", "legendFormat": "{{device}}" }]
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 21 },
      "id": 104,
      "title": "Battery & Device Health",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 20 },
              { "color": "green", "value": 50 }
            ]
          }
        }
      },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 22 },
      "id": 40,
      "options": { "showThresholdLabels": false, "showThresholdMarkers": true, "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Battery Level",
      "type": "gauge",
      "targets": [{ "expr": "aranet_battery_percent{device=~\"$device\"}", "legendFormat": "{{device}}" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "color": { "mode": "palette-classic" }
        }
      },
      "gridPos": { "h": 6, "w": 16, "x": 8, "y": 22 },
      "id": 41,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "calcs": ["min", "lastNotNull"] } },
      "title": "Battery Over Time",
      "type": "timeseries",
      "targets": [{ "expr": "aranet_battery_percent{device=~\"$device\"}", "legendFormat": "{{device}}" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          { "matcher": { "id": "byName", "options": "Success" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Failures" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Duration (ms)" }, "properties": [{ "id": "unit", "value": "ms" }] }
        ]
      },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 28 },
      "id": 42,
      "options": { "footer": { "enablePagination": false } },
      "title": "Device Poll Statistics",
      "type": "table",
      "targets": [
        { "expr": "aranet_device_poll_success_total{device=~\"$device\"}", "legendFormat": "{{device}}", "format": "table", "instant": true, "refId": "A" },
        { "expr": "aranet_device_poll_failure_total{device=~\"$device\"}", "legendFormat": "{{device}}", "format": "table", "instant": true, "refId": "B" },
        { "expr": "aranet_device_poll_duration_ms{device=~\"$device\"}", "legendFormat": "{{device}}", "format": "table", "instant": true, "refId": "C" }
      ],
      "transformations": [
        { "id": "merge", "options": {} },
        { "id": "organize", "options": { "excludeByName": { "Time": true, "__name__": true, "address": false, "instance": true, "job": true }, "renameByName": { "Value #A": "Success", "Value #B": "Failures", "Value #C": "Duration (ms)", "device": "Device", "address": "Address" } } }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["aranet", "iot", "sensors", "air-quality"],
  "templating": {
    "list": [
      {
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(aranet_battery_percent, device)",
        "hide": 0,
        "includeAll": true,
        "label": "Device",
        "multi": true,
        "name": "device",
        "options": [],
        "query": { "query": "label_values(aranet_battery_percent, device)", "refId": "StandardVariableQuery" },
        "refresh": 2,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {
    "refresh_intervals": ["10s", "30s", "1m", "5m"]
  },
  "timezone": "",
  "title": "Aranet Sensors",
  "uid": "aranet-sensors",
  "version": 1
}
